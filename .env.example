# X API
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Bot config
POSTS_PER_DAY=10
POST_START_HOUR=8
POST_END_HOUR=22
TZ=America/Fortaleza
RUN_ON_START=true

# Railway volume
RAILWAY_VOLUME_MOUNT_PATH=/data
